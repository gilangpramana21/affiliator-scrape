{
  "base_url": "https://affiliate-id.tokopedia.com",
  "list_page_url": "/connection/creator-management",
  "list_page_query": "?view_blocked_creator=&shop_region=ID&shop_id=7495177173399997259",
  
  "min_delay": 4.0,
  "max_delay": 9.0,
  "jitter": 0.35,
  
  "hourly_limit": 25,
  "daily_limit": 200,
  "max_session_duration": 3600,
  "break_duration_min": 1200,
  "break_duration_max": 2400,
  "quiet_hours": [[1, 6]],
  
  "request_timeout": 30,
  "max_retries": 3,
  "max_redirects": 5,
  
  "browser_engine": "playwright",
  "headless": true,
  "use_stealth": true,
  
  "proxies": [],
  "proxy_rotation_strategy": "per_session",
  "proxy_rotation_interval": 10,
  
  "captcha_solver": "manual",
  "captcha_api_key": null,
  
  "output_format": "xlsx",
  "output_path": "output/affiliators.xlsx",
  "incremental_save": true,
  "save_interval": 5,
  "cookie_file": "config/cookies.json",
  "require_cookie_file": true,
  "max_pages_per_run": 20,
  "max_errors_before_stop": 10,
  "max_captchas_before_stop": 3,
  
  "log_level": "INFO",
  "log_file": "logs/scraper.log",
  
  "distributed": false,
  "redis_url": null,
  "instance_id": null
